---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Build log - Arjun Pherwani" description="Build-log notes will live here once the home lab notes are ready to publish.">
  <section class="wrap" style="padding-top: 76px;">
    <header class="page-header">
      <h1 class="page-title">Build log</h1>
      <p class="lead">
        Build-log notes will live here once the home lab notes are ready to publish. The intended
        shape is still fixed:
        <span class="mono" style="text-transform:none; letter-spacing:0;">goal -&gt; setup -&gt; worked -&gt; failed -&gt; changed -&gt; next</span>.
      </p>
    </header>

    <div class="rows">
      <div class="row row-static">
        <span class="row-date">pending</span>
        <span class="row-title">
          No published build-log entries yet
          <span class="row-sub">The home lab is listed as work in progress; notes will appear here after they are cleaned up.</span>
        </span>
        <span class="row-meta"><span class="status is-planned"><span class="led" aria-hidden="true"></span>Reset</span></span>
      </div>
    </div>
  </section>
</BaseLayout>
