---
import RowLink from "@/components/RowLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { logEntries } from "@/data/site";

const publishedLogs = logEntries.filter((entry) => entry.published && entry.href);
---

<BaseLayout title="Build log - Arjun Pherwani" description="Hardware, networking, and home-lab notes from Arjun Pherwani.">
  <section class="wrap" style="padding-top: 76px;">
    <header class="page-header">
      <h1 class="page-title">Build log</h1>
      <p class="lead">
        Hardware, networking, and home-lab notes in a fixed shape:
        <span class="mono" style="text-transform:none; letter-spacing:0;">goal -&gt; setup -&gt; worked -&gt; failed -&gt; changed -&gt; next</span>.
      </p>
    </header>

    <div class="rows">
      {
        publishedLogs.map((entry) => (
          <RowLink
            href={entry.href}
            date={entry.date}
            title={`Log ${entry.number}: ${entry.title}`}
            summary={entry.summary}
            meta={entry.tags.join(" / ")}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
