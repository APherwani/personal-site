---
import RowLink from "@/components/RowLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/site";
---

<BaseLayout title="Projects - Arjun Pherwani" description="Upcoming work in progress from Arjun Pherwani: Olive and the home lab.">
  <section class="wrap" style="padding-top: 76px;">
    <header class="page-header">
      <h1 class="page-title">Projects</h1>
      <p class="lead">
        Upcoming work in progress. The detailed project pages are intentionally paused until the
        artifacts and notes are ready to be public.
      </p>
    </header>

    <div class="rows">
      {
        projects.map((project) => (
          <RowLink
            date={project.date}
            title={project.title}
            summary={project.summary}
            status={project.status}
          />
        ))
      }
    </div>

    <p class="mono" style="margin-top: 28px; color: var(--faint);">
      Keep this list short. Add links only when a project has a durable public page.
    </p>
  </section>
</BaseLayout>
