---
import RowLink from "@/components/RowLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/site";
---

<BaseLayout title="Projects - Arjun Pherwani" description="Project notes from Arjun Pherwani: Olive, Coldtrace, Zero Game, Transit Treks, SelfControl launchd automation, and upcoming home lab work.">
  <section class="wrap" style="padding-top: 76px;">
    <header class="page-header">
      <h1 class="page-title">Projects</h1>
      <p class="lead">
        Compact notes on systems, tools, and decisions that are concrete enough to publish. Some
        are active projects; some are small artifacts where the failure mode is the useful part.
      </p>
    </header>

    <div class="rows">
      {
        projects.map((project) => (
          <RowLink
            href={project.href}
            date={project.date}
            title={project.title}
            summary={project.summary}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
