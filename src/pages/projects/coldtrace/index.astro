const artifactBase = "/projects/coldtrace/manual";
const manualArtifacts = [
  {
    label: "Environment",
    href: `${artifactBase}/env.txt`,
    file: "env.txt",
    size: "443 B",
    summary: "VM, kernel, Python path, import path, and torch version.",
  },
  {
    label: "Wall time",
    href: `${artifactBase}/time-posix.txt`,
    file: "time-posix.txt",
    size: "30 B",
    summary: "The POSIX time output for one manual import run.",
  },
  {
    label: "Import timing",
    href: `${artifactBase}/importtime.txt`,
    file: "importtime.txt",
    size: "84 KB",
    summary: "Full Python importtime stderr output.",
  },
  {
    label: "Syscall summary",
    href: `${artifactBase}/strace-summary.txt`,
    file: "strace-summary.txt",
    size: "3.1 KB",
    summary: "Aggregate syscall table from strace.",
  },
  {
    label: "Process status",
    href: `${artifactBase}/proc-status.txt`,
    file: "proc-status.txt",
    size: "1.2 KB",
