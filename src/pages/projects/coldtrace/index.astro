  },
  {
    label: "Cgroup",
    href: `${artifactBase}/proc-cgroup.txt`,
    file: "proc-cgroup.txt",
    size: "47 B",
    summary: "The process cgroup line.",
  },
  {
    label: "Executable",
    href: `${artifactBase}/proc-exe.txt`,
    file: "proc-exe.txt",
    size: "21 B",
    summary: "The resolved executable target.",
  },
  {
    label: "File descriptors",
    href: `${artifactBase}/proc-fd-head.txt`,
    file: "proc-fd-head.txt",
    size: "228 B",
    summary: "The first entries from the process file-descriptor directory.",
  },
  {
    label: "Coldtrace run",
    href: `${artifactBase}/coldtrace-release-torch.txt`,
    file: "coldtrace-release-torch.txt",
    size: "91 B",
    summary: "One release-build wrapper run around the torch import workload.",
  },
  {
    label: "Coldtrace repeats",
    href: `${artifactBase}/coldtrace-release-torch-repeats.txt`,
