---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Writing - Arjun Pherwani" description="Writing will live here once essays are edited and ready for public release.">
  <section class="wrap" style="padding-top: 76px;">
    <header class="page-header">
      <h1 class="page-title">Writing</h1>
      <p class="lead">
        Writing will live here once essays are edited and ready for public release. For now, the
        archive has been cleared so unfinished drafts do not look like published work.
      </p>
    </header>

    <div class="rows">
      <div class="row row-static">
        <span class="row-date">pending</span>
        <span class="row-title">
          No published essays yet
          <span class="row-sub">The writing shelf is intentionally empty until a piece is ready to publish.</span>
        </span>
        <span class="row-meta"><span class="status is-planned"><span class="led" aria-hidden="true"></span>Reset</span></span>
      </div>
    </div>

    <p class="mono" style="margin-top: 28px; color: var(--faint);">
      New writing should be added deliberately, with a real route and release note.
    </p>
  </section>
</BaseLayout>
