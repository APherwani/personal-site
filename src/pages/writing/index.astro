---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RowLink from "@/components/RowLink.astro";
import { formatDate, writing } from "@/data/site";

const publishedWriting = writing.filter((item) => item.published && item.href);
---

<BaseLayout title="Writing - Arjun Pherwani" description="Essays from Arjun Pherwani on systems, behavior, work, and decision-making.">
  <section class="wrap" style="padding-top: 76px;">
    <header class="page-header">
      <h1 class="page-title">Writing</h1>
      <p class="lead">
        Essays and notes that are edited enough to publish. The shelf starts small on purpose.
      </p>
    </header>

    <div class="rows">
      {
        publishedWriting.map((item) => (
          <RowLink
            href={item.href}
            date={formatDate(item.date)}
            title={item.title}
            summary={item.summary}
            meta={item.readingTime}
          />
        ))
      }
    </div>

    <p class="mono" style="margin-top: 28px; color: var(--faint);">
      New writing should be added deliberately, with a real route, RSS entry, and release note.
    </p>
  </section>
</BaseLayout>
